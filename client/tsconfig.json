{
  "compilerOptions": {
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "target": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ESNext"],

    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "types": ["react", "react-dom"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"]
}